VIDEO_DB_API_KEY=
VIDEO_DB_BASE_URL=https://api.videodb.io

# Notion
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
NOTION_VERSION=2022-06-28

# LLM provider (OpenAI-compatible)
# Used by curator + Event Designer tool-calling.
OPENAI_API_KEY=
# Optional override for OpenAI-compatible endpoints
OPENAI_BASE_URL=

# Model routing (sandbox aligned)
# OpenAI models are safe defaults for local demo reliability.
CURATOR_MODEL=gpt-4.1-mini
CURATOR_FALLBACK_MODEL=gpt-4o-mini
TOOL_PLANNER_MODEL=gpt-4o-mini

# VideoDB sandbox + indexing
USE_SANDBOX=true
SANDBOX_TIER=small
SANDBOX_IDLE_TIMEOUT=900
CAPTURE_CLIENT_TOKEN_TTL_SECONDS=1800
VISUAL_INDEX_MODEL=google/gemma-4-E2B-it
# Optional multiple visual index prompts on same RTStream (separate with ||)
VISUAL_INDEX_PROMPTS=
AUDIO_INDEX_MODEL=Qwen/Qwen3.5-9B

# Runtime
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
CURATOR_INITIAL_WINDOW_SECONDS=12
CURATOR_WINDOW_SECONDS=30
NOTION_BATCH_INTERVAL_S=4
SCREENSHOT_LOCAL_FALLBACK=true
SCREENSHOT_LOCAL_FIRST=false
