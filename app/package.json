    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.2.1",
    "electron": "^39.2.6",
    "typescript": "^5.5.4",
    "vite": "^7.0.0",
    "wait-on": "^9.0.3"
  }
}
